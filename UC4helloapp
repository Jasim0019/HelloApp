public class HelloApp {
    public static void main(String[] args) {
        
        // Check if user provided any names as command-line arguments
        if (args.length > 0) {
            // Loop through all arguments and greet each person
            for (int i = 0; i < args.length; i++) {
                String name = args[i];
                System.out.println("Hello " + name);
            }
        } else {
            // No arguments provided, use default "World"
            String defaultName = "World";
            System.out.println("Hello " + defaultName);
        }
        
    }
}